<mxGraphModel dx="1140" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="660" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <mxCell id="title" value="From BSP Phases to Tile-Level Asynchronous Rendezvous" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="10" width="1100" height="30" as="geometry"/>
    </mxCell>

    <!-- Left: BSP -->
    <mxCell id="bsp" value="Classic BSP collective — coarse all-ranks phases" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="460" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_c1" value="Compute phase&#10;(entire tensor)" style="rounded=0;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="bsp">
      <mxGeometry x="100" y="46" width="300" height="64" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_b1" value="Host barrier — all ranks wait" style="rounded=0;whiteSpace=wrap;fillColor=#fde0dc;strokeColor=#b85450;fontStyle=2;" vertex="1" parent="bsp">
      <mxGeometry x="100" y="128" width="300" height="36" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_m1" value="Communicate phase&#10;(entire tensor)" style="rounded=0;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#b85450;" vertex="1" parent="bsp">
      <mxGeometry x="100" y="182" width="300" height="64" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_b2" value="Host barrier — all ranks wait" style="rounded=0;whiteSpace=wrap;fillColor=#fde0dc;strokeColor=#b85450;fontStyle=2;" vertex="1" parent="bsp">
      <mxGeometry x="100" y="264" width="300" height="36" as="geometry"/>
    </mxCell>
