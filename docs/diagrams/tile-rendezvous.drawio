    <mxCell id="tx_note" value="Each tile is produced, transferred, flag-synchronized, and consumed independently. AICore observes data readiness and runtime state, choosing IPC/MTE, UDMA, or SDMA and advancing without repeated host round-trips, so stages of different tiles overlap." style="text;html=1;align=center;whiteSpace=wrap;fontColor=#2d6a2d;" vertex="1" parent="tx">
