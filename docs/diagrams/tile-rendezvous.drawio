      <mxGeometry x="100" y="318" width="300" height="64" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_note" value="Communication advances only at coarse all-ranks barriers.&#10;The device repeatedly returns to host scheduling; fast ranks idle while waiting for the slowest." style="text;html=1;align=center;whiteSpace=wrap;fontColor=#a02020;" vertex="1" parent="bsp">
      <mxGeometry x="30" y="400" width="400" height="100" as="geometry"/>
    </mxCell>
    <mxCell id="bsp_time" value="time &#8595;" style="text;html=1;align=center;rotation=0;fontStyle=1;fontColor=#b85450;" vertex="1" parent="bsp">
      <mxGeometry x="20" y="180" width="60" height="30" as="geometry"/>
    </mxCell>

